{
  "buildCommand": "echo 'Blog application ready for deployment'",
  "outputDirectory": "./",
  "public": true,
  "routes": [
    {
      "src": "/favicon.ico",
      "dest": "/favicon.ico"
    },
    {
      "src": "/favicon.png",
      "dest": "/favicon.png"
    },
    {
      "src": "/(.*\\.(css|js|ico|png|jpg|jpeg|gif|svg|woff|woff2|ttf))$",
      "dest": "/$1"
    },
    {
      "src": "/blog",
      "dest": "/blog/blogHome.html"
    },
    {
      "src": "/blog/(.*)",
      "dest": "/blog/blogHome.html"
    },
    {
      "src": "/viewPost",
      "dest": "/viewPost/viewPost.html"
    },
    {
      "src": "/loginSignup",
      "dest": "/loginSignup/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/loginSignup/index.html"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://api.null-blog.vercel.app/api/$1"
    }
  ]
}
