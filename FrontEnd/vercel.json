{
  "buildCommand": "echo 'Blog application ready for deployment'",
  "outputDirectory": "./",
  "public": true,
  "cleanUrls": true,
  "headers": [
    {
      "source": "/loginSignup/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/blog/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/viewPost/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://api.null-blog.vercel.app/api/$1"
    },
    {
      "source": "/blog",
      "destination": "/blog/blogHome.html"
    },
    {
      "source": "/viewPost",
      "destination": "/viewPost/viewPost.html"
    },
    {
      "source": "/loginSignup",
      "destination": "/loginSignup/index.html"
    },
    {
      "source": "/((?!.*\\.).*)",
      "destination": "/loginSignup/index.html"
    }
  ]
}
