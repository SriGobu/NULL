{
  "buildCommand": "echo 'Blog application ready for deployment'",
  "outputDirectory": "./",
  "public": true,
  "routes": [
    {
      "src": "/blog",
      "dest": "/blog/blogHome.html"
    },
    {
      "src": "/blog/(.*)",
      "dest": "/blog/blogHome.html"
    },
    {
      "src": "/viewPost",
      "dest": "/viewPost/viewPost.html"
    },
    {
      "src": "/loginSignup",
      "dest": "/loginSignup/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/loginSignup/index.html"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "http://localhost:3000/api/$1"
    }
  ]
}
