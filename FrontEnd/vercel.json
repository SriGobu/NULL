{
  "buildCommand": "echo 'Blog application ready for deployment'",
  "outputDirectory": "./",
  "public": true,
  "cleanUrls": false,
  "headers": [
    {
      "source": "/(.*)\\.css",
      "headers": [{ "key": "Content-Type", "value": "text/css" }]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [{ "key": "Content-Type", "value": "application/javascript" }]
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://api.null-blog.vercel.app/api/$1"
    },
    {
      "source": "/blog",
      "destination": "/blog/blogHome.html"
    },
    {
      "source": "/viewPost",
      "destination": "/viewPost/viewPost.html"
    },
    {
      "source": "/loginSignup",
      "destination": "/loginSignup/index.html"
    }
  ]
}